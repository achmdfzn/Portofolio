# ──────────────────────────────────────────────────────────────────────────
#  Portofolio Achmad Fauzan — Environment Variables
#  Salin file ini menjadi `.env.local` (frontend) / `.env` (backend) lalu isi.
#  JANGAN pernah commit file `.env.local` / `.env` berisi nilai asli.
# ──────────────────────────────────────────────────────────────────────────

# ══════════════════ FRONTEND (Next.js) ══════════════════
# Ekspos aman ke browser — boleh diawali NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alamat backend FastAPI (mis. http://localhost:8000 untuk dev lokal).
NEXT_PUBLIC_API_URL=

# ══════════════════ BACKEND (FastAPI) ══════════════════
# Catatan: stack backend ditunda di Phase 0 (frontend-first).
# Variabel di bawah didokumentasikan agar siap dipakai saat fase backend.

# Supabase project URL (sama nilai dengan NEXT_PUBLIC_SUPABASE_URL).
SUPABASE_URL=
# SERVICE_ROLE KEY — RAHASIA. Bisa melewati Row Level Security.
# JANGAN pernah ekspos ke sisi frontend (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=
# Daftar origin yang boleh memanggil API, dipisah koma.
# Contoh: http://localhost:3000,https://achmadfauzan.dev
ALLOWED_ORIGINS=
